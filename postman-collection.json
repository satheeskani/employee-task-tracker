{
  "info": {
    "name": "Employee Task Tracker API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api" },
    { "key": "employeeId", "value": "" },
    { "key": "taskId", "value": "" }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "url": "http://localhost:3000/health"
      }
    },
    {
      "name": "Employees",
      "item": [
        {
          "name": "Create Employee",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.success) pm.collectionVariables.set('employeeId', json.data._id);",
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Has _id', () => pm.expect(json.data._id).to.be.a('string'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/employees",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Priya Sharma\",\n  \"email\": \"priya@company.com\",\n  \"role\": \"Frontend Developer\"\n}"
            }
          }
        },
        {
          "name": "List All Employees",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/employees"
          }
        },
        {
          "name": "Get Employee by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/employees/{{employeeId}}"
          }
        },
        {
          "name": "Create Employee — Validation Error",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/employees",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"\",\n  \"email\": \"not-an-email\",\n  \"role\": \"\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Tasks",
      "item": [
        {
          "name": "Create Task",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.success) pm.collectionVariables.set('taskId', json.data._id);",
                  "pm.test('Status 201', () => pm.response.to.have.status(201));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/tasks",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"employee_id\": \"{{employeeId}}\",\n  \"task_title\": \"Build login page\",\n  \"status\": \"pending\"\n}"
            }
          }
        },
        {
          "name": "List Tasks by Employee",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/tasks/employee/{{employeeId}}"
          }
        },
        {
          "name": "Update Task Status",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/tasks/{{taskId}}/status",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"in-progress\"\n}"
            }
          }
        },
        {
          "name": "Update Task Status — Invalid Value",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/tasks/{{taskId}}/status",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"done\"\n}"
            }
          }
        },
        {
          "name": "Get Single Task",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/tasks/{{taskId}}"
          }
        }
      ]
    }
  ]
}
